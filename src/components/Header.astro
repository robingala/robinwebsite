---
// ============================================
// ROBIN GARTENBAU - STICKY HEADER
// ============================================
// Responsive Navigation mit Mobile Menu
// ============================================

import { Image } from 'astro:assets';

// Navigation Links
const navLinks = [
  { href: '#leistungen', label: 'Leistungen', ariaLabel: 'Zu den Leistungen springen' },
  { href: '#ueber-uns', label: 'Über uns', ariaLabel: 'Zur Über uns Sektion springen' },
  { href: '#galerie', label: 'Galerie', ariaLabel: 'Zur Galerie springen' },
  { href: '#kontakt', label: 'Kontakt', ariaLabel: 'Zum Kontaktformular springen' },
];

// Kontaktdaten
const phoneNumber = '+491785361122';
const phoneDisplay = '0178 5361122';
---

<header 
  class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-md shadow-sm transition-all duration-300"
  role="banner"
  id="main-header"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      
      <!-- Logo Bild -->
      <a 
        href="/" 
        class="flex items-center group"
        aria-label="Zur Startseite von Robin Garten- und Landschaftsbau"
      >
        <Image 
          src="/images/logo.png" 
          alt="Robin Garten- und Landschaftsbau Logo" 
          width={200}
          height={60}
          class="h-12 lg:h-16 w-auto object-contain transition-transform duration-300 group-hover:scale-105"
          loading="eager"
          decoding="async"
        />
      </a>

      <!-- Desktop Navigation -->
      <nav 
        class="hidden lg:flex items-center gap-8" 
        role="navigation" 
        aria-label="Hauptnavigation"
      >
        <ul class="flex items-center gap-6">
          {navLinks.map((link) => (
            <li>
              <a 
                href={link.href}
                class="relative py-2 text-secondary-700 font-medium hover:text-primary transition-colors duration-200 after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-primary after:transition-all after:duration-300 hover:after:w-full"
                aria-label={link.ariaLabel}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- CTA Button: Jetzt Anrufen -->
        <a 
          href={`tel:${phoneNumber}`}
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary text-white font-semibold rounded-lg shadow-md hover:bg-primary-600 hover:shadow-lg transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-primary-400 focus:ring-offset-2"
          aria-label={`Jetzt anrufen unter ${phoneDisplay}`}
        >
          <svg 
            class="w-5 h-5" 
            fill="none" 
            stroke="currentColor" 
            viewBox="0 0 24 24" 
            aria-hidden="true"
          >
            <path 
              stroke-linecap="round" 
              stroke-linejoin="round" 
              stroke-width="2" 
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            />
          </svg>
          <span>Jetzt anrufen</span>
        </a>
      </nav>

      <!-- Mobile: Call Button (schneller Zugriff) -->
      <div class="flex items-center gap-2 lg:hidden">
        <a 
          href={`tel:${phoneNumber}`}
          class="p-2.5 bg-primary text-white rounded-lg shadow-md hover:bg-primary-600 transition-colors duration-200"
          aria-label={`Jetzt anrufen unter ${phoneDisplay}`}
        >
          <svg 
            class="w-5 h-5" 
            fill="none" 
            stroke="currentColor" 
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path 
              stroke-linecap="round" 
              stroke-linejoin="round" 
              stroke-width="2" 
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            />
          </svg>
        </a>

        <!-- Mobile Menu Toggle -->
        <button 
          type="button"
          id="mobile-menu-toggle"
          class="p-2.5 text-secondary-700 hover:text-primary transition-colors duration-200 rounded-lg hover:bg-secondary-50"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Navigation öffnen"
        >
          <svg 
            class="w-6 h-6 menu-icon" 
            fill="none" 
            stroke="currentColor" 
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path 
              stroke-linecap="round" 
              stroke-linejoin="round" 
              stroke-width="2" 
              d="M4 6h16M4 12h16M4 18h16"
            />
          </svg>
          <svg 
            class="w-6 h-6 close-icon hidden" 
            fill="none" 
            stroke="currentColor" 
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path 
              stroke-linecap="round" 
              stroke-linejoin="round" 
              stroke-width="2" 
              d="M6 18L18 6M6 6l12 12"
            />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div 
    id="mobile-menu" 
    class="hidden lg:hidden bg-white border-t border-secondary-100"
    role="navigation" 
    aria-label="Mobile Navigation"
  >
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-1">
      {navLinks.map((link) => (
        <a 
          href={link.href}
          class="block px-4 py-3 text-secondary-700 font-medium rounded-lg hover:bg-secondary-50 hover:text-primary transition-colors duration-200 mobile-nav-link"
          aria-label={link.ariaLabel}
        >
          {link.label}
        </a>
      ))}
      
      <!-- Mobile CTA -->
      <div class="pt-4 mt-4 border-t border-secondary-100">
        <a 
          href={`tel:${phoneNumber}`}
          class="flex items-center justify-center gap-2 w-full px-4 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-primary-600 transition-colors duration-200"
          aria-label={`Jetzt anrufen unter ${phoneDisplay}`}
        >
          <svg 
            class="w-5 h-5" 
            fill="none" 
            stroke="currentColor" 
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path 
              stroke-linecap="round" 
              stroke-linejoin="round" 
              stroke-width="2" 
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            />
          </svg>
          <span>{phoneDisplay} - Jetzt anrufen</span>
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer für fixed Header -->
<div class="h-16 lg:h-20" aria-hidden="true"></div>

<script>
  // Mobile Menu Toggle Logic
  (function() {
    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = toggleBtn?.querySelector('.menu-icon');
    const closeIcon = toggleBtn?.querySelector('.close-icon');
    const mobileLinks = mobileMenu?.querySelectorAll('.mobile-nav-link');
    
    let isOpen = false;
    
    function toggleMenu() {
      isOpen = !isOpen;
      
      if (isOpen) {
        mobileMenu?.classList.remove('hidden');
        mobileMenu?.classList.add('animate-slide-down');
        menuIcon?.classList.add('hidden');
        closeIcon?.classList.remove('hidden');
        toggleBtn?.setAttribute('aria-expanded', 'true');
        toggleBtn?.setAttribute('aria-label', 'Navigation schließen');
        document.body.style.overflow = 'hidden';
      } else {
        mobileMenu?.classList.add('hidden');
        mobileMenu?.classList.remove('animate-slide-down');
        menuIcon?.classList.remove('hidden');
        closeIcon?.classList.add('hidden');
        toggleBtn?.setAttribute('aria-expanded', 'false');
        toggleBtn?.setAttribute('aria-label', 'Navigation öffnen');
        document.body.style.overflow = '';
      }
    }
    
    toggleBtn?.addEventListener('click', toggleMenu);
    
    // Schließe Menu beim Klick auf Link
    mobileLinks?.forEach(link => {
      link.addEventListener('click', () => {
        if (isOpen) toggleMenu();
      });
    });
    
    // Schließe Menu bei Escape-Taste
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        toggleMenu();
      }
    });
  })();
</script>
