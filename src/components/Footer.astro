---
// ============================================
// ROBIN GARTENBAU - FOOTER
// ============================================
// Vollständiger Footer mit Navigation & Kontakt
// ============================================

import { Image } from 'astro:assets';

// Unternehmensdaten
const company = {
  name: 'Robin Garten- und Landschaftsbau',
  shortName: 'Robin Galabau',
  owner: 'Kayhan Özer',
  address: 'Lauenhäger Straße 53a',
  city: '31655 Stadthagen',
  phone: '+491785361122',
  phoneDisplay: '0178 5361122',
  email: 'info@robingartenbau.de',
  whatsapp: 'https://wa.me/491785361122',
};

// Leistungen für Footer-Navigation
const services = [
  { label: 'Galabau', href: '#leistungen' },
  { label: 'Gartenpflege', href: '#leistungen' },
  { label: 'Rollrasen', href: '#leistungen' },
  { label: 'Mähroboter', href: '#leistungen' },
  { label: 'Rasenbewässerung', href: '#leistungen' },
  { label: 'Zaunbau', href: '#leistungen' },
  { label: 'Terrassenbau', href: '#leistungen' },
];

// Aktuelles Jahr für Copyright
const currentYear = new Date().getFullYear();
---

<footer class="bg-secondary text-white" role="contentinfo">
  <!-- Haupt-Footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      
      <!-- Spalte 1: Über uns -->
      <div class="lg:col-span-1">
        <div class="mb-4">
          <Image 
            src="/images/logo.png" 
            alt="Robin Garten- und Landschaftsbau Logo" 
            width={180}
            height={50}
            class="h-10 w-auto object-contain"
            loading="lazy"
            decoding="async"
          />
        </div>
        <p class="text-secondary-200 text-sm leading-relaxed mb-4">
          Ihr zuverlässiger Partner für Garten- und Landschaftsbau in Stadthagen und Umgebung. 
          Inhabergeführt, professionell und mit Leidenschaft für grüne Oasen.
        </p>
        <!-- Social / Trust Badges -->
        <div class="flex items-center gap-3">
          <span class="inline-flex items-center gap-1 px-3 py-1 bg-primary/20 text-primary-300 text-xs font-medium rounded-full">
            <i class="fa-solid fa-circle-check" style="font-size: 16px; color: #a3d977;"></i>
            Inhabergeführt
          </span>
          <span class="inline-flex items-center gap-1 px-3 py-1 bg-primary/20 text-primary-300 text-xs font-medium rounded-full">
            <i class="fa-solid fa-circle-check" style="font-size: 16px; color: #a3d977;"></i>
            Zuverlässig
          </span>
        </div>
      </div>

      <!-- Spalte 2: Leistungen -->
      <div>
        <h3 class="text-lg font-semibold mb-4 text-white">Leistungen</h3>
        <ul class="space-y-2" role="list">
          {services.map((service) => (
            <li>
              <a 
                href={service.href}
                class="text-secondary-200 hover:text-primary transition-colors duration-200 text-sm"
                aria-label={`Mehr erfahren über ${service.label}`}
              >
                {service.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Spalte 3: Schnelllinks -->
      <div>
        <h3 class="text-lg font-semibold mb-4 text-white">Navigation</h3>
        <ul class="space-y-2" role="list">
          <li>
            <a href="/" class="text-secondary-200 hover:text-primary transition-colors duration-200 text-sm">
              Startseite
            </a>
          </li>
          <li>
            <a href="#leistungen" class="text-secondary-200 hover:text-primary transition-colors duration-200 text-sm">
              Leistungen
            </a>
          </li>
          <li>
            <a href="#ueber-uns" class="text-secondary-200 hover:text-primary transition-colors duration-200 text-sm">
              Über uns
            </a>
          </li>
          <li>
            <a href="#galerie" class="text-secondary-200 hover:text-primary transition-colors duration-200 text-sm">
              Galerie
            </a>
          </li>
          <li>
            <a href="#kontakt" class="text-secondary-200 hover:text-primary transition-colors duration-200 text-sm">
              Kontakt
            </a>
          </li>
          <li>
            <a href="/impressum" class="text-secondary-200 hover:text-primary transition-colors duration-200 text-sm">
              Impressum
            </a>
          </li>
          <li>
            <a href="/datenschutz" class="text-secondary-200 hover:text-primary transition-colors duration-200 text-sm">
              Datenschutz
            </a>
          </li>
        </ul>
      </div>

      <!-- Spalte 4: Kontakt -->
      <div>
        <h3 class="text-lg font-semibold mb-4 text-white">Kontakt</h3>
        <address class="not-italic space-y-3">
          <div class="flex items-start gap-3">
            <i class="fa-solid fa-location-dot" style="font-size: 20px; color: #6fa822;"></i>
            <span class="text-secondary-200 text-sm">
              {company.address}<br />
              {company.city}
            </span>
          </div>
          
          <div class="flex items-center gap-3">
            <i class="fa-solid fa-phone" style="font-size: 20px; color: #6fa822;"></i>
            <a 
              href={`tel:${company.phone}`}
              class="text-secondary-200 hover:text-primary transition-colors duration-200 text-sm"
              aria-label={`Telefon: ${company.phoneDisplay}`}
            >
              {company.phoneDisplay}
            </a>
          </div>
          
          <div class="flex items-center gap-3">
            <i class="fa-solid fa-envelope" style="font-size: 20px; color: #6fa822;"></i>
            <a 
              href={`mailto:${company.email}`}
              class="text-secondary-200 hover:text-primary transition-colors duration-200 text-sm"
              aria-label={`E-Mail: ${company.email}`}
            >
              {company.email}
            </a>
          </div>
        </address>

        <!-- CTA Buttons im Footer -->
        <div class="mt-6 space-y-2">
          <a 
            href={company.whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 w-full px-4 py-2.5 bg-green-600 text-white font-medium rounded-lg hover:bg-green-700 transition-colors duration-200"
            aria-label="Jetzt per WhatsApp schreiben"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp schreiben
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Copyright Bar -->
  <div class="border-t border-secondary-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-2 text-sm text-secondary-300">
        <p>
          © {currentYear} {company.name} - Inh. {company.owner}
        </p>
        <div class="flex items-center gap-4">
          <a href="/impressum" class="hover:text-white transition-colors duration-200">
            Impressum
          </a>
          <span class="text-secondary-600" aria-hidden="true">|</span>
          <a href="/datenschutz" class="hover:text-white transition-colors duration-200">
            Datenschutz
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
