---
// ============================================
// ROBIN GARTENBAU - DANKE SEITE
// ============================================
// Bestätigungsseite nach Formular-Absendung
// ============================================

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = 'Vielen Dank! | Robin Garten- und Landschaftsbau';
const pageDescription = 'Ihre Anfrage wurde erfolgreich versendet. Wir melden uns schnellstmöglich bei Ihnen.';

const contact = {
  phone: '+491785361122',
  phoneDisplay: '0178 5361122',
  whatsapp: 'https://wa.me/491785361122',
};
---

<Layout 
  title={pageTitle} 
  description={pageDescription}
  noindex={true}
>
  <Header slot="header" />

  <section class="py-24 lg:py-32 bg-secondary-50 flex items-center justify-center" aria-labelledby="thanks-title">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      
      <!-- Success Icon -->
      <div class="mb-8">
        <div class="w-24 h-24 mx-auto bg-green-100 rounded-full flex items-center justify-center">
          <svg class="w-12 h-12 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
      </div>

      <h1 id="thanks-title" class="text-3xl sm:text-4xl font-bold text-secondary-900 mb-4">
        Vielen Dank für Ihre Anfrage!
      </h1>
      
      <p class="text-lg text-secondary-600 mb-8 max-w-lg mx-auto">
        Wir haben Ihre Nachricht erfolgreich erhalten. Unser Team wird sich in Kürze mit Ihnen 
        in Verbindung setzen, um Ihr Projekt zu besprechen.
      </p>

      <!-- Nächste Schritte -->
      <div class="bg-white rounded-2xl p-6 sm:p-8 shadow-sm mb-8 text-left">
        <h2 class="text-lg font-semibold text-secondary-900 mb-4">Was passiert als Nächstes?</h2>
        <ul class="space-y-3 text-secondary-600">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>Wir prüfen Ihre Anfrage innerhalb von 24 Stunden</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>Sie erhalten ein unverbindliches Angebot</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>Gemeinsam besprechen wir die Details Ihres Projekts</span>
          </li>
        </ul>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-semibold rounded-lg shadow-md hover:bg-primary-600 hover:shadow-lg transition-all duration-200"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          Zurück zur Startseite
        </a>
        
        <a 
          href={contact.whatsapp}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 bg-green-500 text-white font-semibold rounded-lg shadow-md hover:bg-green-600 hover:shadow-lg transition-all duration-200"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp schreiben
        </a>
      </div>

      <!-- Kontakt-Hinweis -->
      <div class="mt-12 pt-8 border-t border-secondary-200">
        <p class="text-secondary-500 text-sm">
          Bei dringenden Anfragen erreichen Sie uns auch telefonisch:<br />
          <a href={`tel:${contact.phone}`} class="text-primary font-medium hover:underline">
            {contact.phoneDisplay}
          </a>
        </p>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
