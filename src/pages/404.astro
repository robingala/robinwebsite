---
// ============================================
// ROBIN GARTENBAU - 404 FEHLERSEITE
// ============================================

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = 'Seite nicht gefunden | Robin Garten- und Landschaftsbau';
const pageDescription = 'Die angeforderte Seite wurde nicht gefunden. Zurück zur Startseite von Robin Garten- und Landschaftsbau in Stadthagen.';
---

<Layout 
  title={pageTitle} 
  description={pageDescription}
  noindex={true}
>
  <Header slot="header" />

  <section class="py-24 lg:py-32 bg-secondary-50 flex items-center justify-center" aria-labelledby="error-title">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      
      <!-- 404 Icon -->
      <div class="mb-8">
        <svg class="w-32 h-32 mx-auto text-secondary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
      </div>

      <h1 id="error-title" class="text-6xl sm:text-8xl font-bold text-secondary-900 mb-4">
        404
      </h1>
      
      <p class="text-2xl sm:text-3xl font-semibold text-secondary-800 mb-4">
        Seite nicht gefunden
      </p>
      
      <p class="text-lg text-secondary-600 mb-8 max-w-md mx-auto">
        Die von Ihnen gesuchte Seite existiert leider nicht oder wurde verschoben.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-semibold rounded-lg shadow-md hover:bg-primary-600 hover:shadow-lg transition-all duration-200"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          Zur Startseite
        </a>
        
        <a 
          href="/#kontakt" 
          class="inline-flex items-center gap-2 px-6 py-3 bg-white text-secondary-700 font-semibold rounded-lg shadow-sm border border-secondary-200 hover:bg-secondary-50 transition-all duration-200"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Kontakt aufnehmen
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
